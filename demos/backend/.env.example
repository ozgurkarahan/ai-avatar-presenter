# =============================================================
# AI Presenter — Environment Configuration Template
# =============================================================
# Copy to .env and fill in values. Do NOT commit .env files.
# =============================================================

# --- Azure AI Speech / AI Services (avatar rendering) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=swedencentral
AZURE_SPEECH_ENDPOINT=https://<your-ai-services-name>.cognitiveservices.azure.com/
AZURE_SPEECH_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>

# --- Azure OpenAI (translation + Q&A) ---
AZURE_OPENAI_ENDPOINT=https://<your-openai-name>.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Auth: managed identity (DefaultAzureCredential) or key-based ---
AZURE_USE_MANAGED_IDENTITY=true

# --- LibreOffice: path to soffice binary (for PPTX rendering) ---
# Docker: "soffice" (on PATH)
# Windows: C:\Program Files\LibreOffice\program\soffice.exe
LIBREOFFICE_PATH=soffice
