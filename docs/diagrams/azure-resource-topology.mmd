graph TD
    subgraph RG["Resource Group: rg-{environment}"]
        subgraph Compute["Compute"]
            ACR["Azure Container Registry<br/>(Basic) — cr{token}"]
            CAE["Container App Environment<br/>cae-{token}"]
            CA["Container App<br/>ca-{token}<br/>1 vCPU · 2 GiB · 1-3 replicas"]
            LOG["Log Analytics Workspace<br/>cae-{token}-logs<br/>30-day retention"]
        end

        subgraph AI["AI Services"]
            AIS["Azure AI Services (S0)<br/>ais-{token}<br/>• VoiceLive Avatar API<br/>• Batch Synthesis API<br/>• DragonHD TTS voices<br/>• ICE/TURN relay"]
            OAI["Azure OpenAI (S0)<br/>oai-{token}<br/>• gpt-4.1 (80 TPM)<br/>• text-embedding-3-small (120 TPM)"]
        end

        subgraph Data["Data & Storage"]
            CDB["Azure Cosmos DB<br/>(Serverless) — cosmos-{token}<br/>DB: ai-presenter<br/>Container: presentations"]
            STG["Azure Storage (Std LRS)<br/>st{token}<br/>Container: slide-images<br/>(private, SAS access)"]
        end
    end

    CA -->|"Managed Identity<br/>Cognitive Services Speech User<br/>Cognitive Services User"| AIS
    CA -->|"Managed Identity<br/>Cognitive Services OpenAI User"| OAI
    CA -->|"Managed Identity<br/>Cosmos DB Data Contributor"| CDB
    CA -->|"Managed Identity<br/>Storage Blob Data Contributor"| STG
    ACR -->|"Docker image pull"| CA
    CAE -->|"App logs"| LOG
    CA ---|"Runs in"| CAE

    classDef compute fill:#e3f2fd,stroke:#1565c0,color:#1a1a1a
    classDef ai fill:#f3e5f5,stroke:#7b1fa2,color:#1a1a1a
    classDef data fill:#e8f5e9,stroke:#2e7d32,color:#1a1a1a
    classDef group fill:#fafafa,stroke:#bdbdbd,color:#1a1a1a

    class ACR,CAE,CA,LOG compute
    class AIS,OAI ai
    class CDB,STG data
