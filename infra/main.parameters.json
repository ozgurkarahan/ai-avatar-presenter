{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "authClientId": {
      "value": "${AUTH_CLIENT_ID}"
    },
    "useExternalAiServices": {
      "value": "${USE_EXTERNAL_AI_SERVICES=false}"
    },
    "externalAiServicesEndpoint": {
      "value": "${EXTERNAL_AI_SERVICES_ENDPOINT=}"
    },
    "externalAiServicesRegion": {
      "value": "${EXTERNAL_AI_SERVICES_REGION=}"
    },
    "externalAiServicesResourceId": {
      "value": "${EXTERNAL_AI_SERVICES_RESOURCE_ID=}"
    }
  }
}
